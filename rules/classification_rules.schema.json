{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resume Classification Rules Schema",
  "description": "简历分类规则的 JSON Schema 定义，用于规则验证和编辑器智能提示",
  "type": "object",
  "required": ["version", "config", "overlay_tags", "categories"],
  "properties": {
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "description": "规则版本号，遵循 semver 格式",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string" },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "last_updated": {
      "type": "string",
      "description": "最后更新日期，格式 YYYY-MM-DD"
    },

    "config": {
      "type": "object",
      "description": "全局配置",
      "required": ["match_mode", "match_strategy", "fallback_category"],
      "properties": {
        "match_mode": {
          "type": "string",
          "enum": ["case_insensitive", "case_sensitive"],
          "description": "关键词匹配大小写策略，默认大小写不敏感"
        },
        "match_strategy": {
          "type": "string",
          "enum": ["first_match", "best_match", "all_match"],
          "description": "匹配策略：first_match=命中即停，best_match=取最高分，all_match=返回所有"
        },
        "fallback_category": {
          "type": "string",
          "description": "兜底分类 ID，无法匹配任何关键词时使用"
        },
        "supported_extensions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "支持的文件扩展名列表"
        },
        "internal_folders": {
          "type": "array",
          "items": { "type": "string" },
          "description": "内部特殊文件夹，不参与归类扫描"
        }
      }
    },

    "overlay_tags": {
      "type": "array",
      "description": "横切叠加标签，优先级高于主分类，可同时命中多个",
      "items": {
        "type": "object",
        "required": ["id", "name", "keywords"],
        "properties": {
          "id": {
            "type": "string",
            "description": "标签唯一 ID",
            "pattern": "^TAG_[A-Z_]+$"
          },
          "name": {
            "type": "string",
            "description": "标签显示名称"
          },
          "description": {
            "type": "string",
            "description": "标签说明"
          },
          "priority": {
            "type": "integer",
            "description": "优先级，数字越小越高",
            "minimum": 1
          },
          "exclusive": {
            "type": "boolean",
            "description": "是否互斥（true=只命中最高优先级，false=可叠加）"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "触发该标签的关键词列表"
          }
        }
      }
    },

    "categories": {
      "type": "array",
      "description": "主分类规则列表，按 order 顺序匹配，first_match 策略下命中即停",
      "items": {
        "type": "object",
        "required": ["id", "name", "keywords"],
        "properties": {
          "id": {
            "type": "string",
            "description": "分类唯一 ID，同时是目标文件夹名"
          },
          "name": {
            "type": "string",
            "description": "分类显示名称"
          },
          "description": {
            "type": "string",
            "description": "分类说明及注意事项"
          },
          "order": {
            "type": "integer",
            "description": "匹配顺序，数字越小越先匹配（精确词应在前）",
            "minimum": 1
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "触发该分类的关键词列表，越精确的词越靠前"
          }
        }
      }
    },

    "legacy_mapping": {
      "type": "object",
      "description": "旧分类名称映射，用于迁移历史简历库的文件夹结构",
      "additionalProperties": { "type": "string" }
    }
  }
}
